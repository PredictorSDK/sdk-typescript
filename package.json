{
  "name": "@predictorsdk/client",
  "version": "0.3.0",
  "description": "The official TypeScript/JavaScript client for the PredictorSDK matching markets API",
  "license": "MIT",
  "keywords": [
    "predictorsdk",
    "sports",
    "betting",
    "prediction-markets",
    "kalshi",
    "polymarket",
    "sdk"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/PredictorSDK/sdk-typescript.git"
  },
  "homepage": "https://docs.predictorsdk.com",
  "bugs": {
    "url": "https://github.com/PredictorSDK/sdk-typescript/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^5.7.0"
  }
}
